{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Cultural Resonance design tokens · v0.1 · 2026-05-16. DTCG format for cross-tool sync (Figma Tokens Studio, Style Dictionary, etc.). The canonical implementation lives in tokens.css.",

  "primitive": {
    "parchment": {
      "50":  { "$type": "color", "$value": "#FBF8F1", "$description": "Lightest cream — raised surface" },
      "100": { "$type": "color", "$value": "#F5F1E8", "$description": "Canvas — primary background" },
      "200": { "$type": "color", "$value": "#ECE6D6", "$description": "Sunken — staff infill / selected state" }
    },
    "sand": {
      "300": { "$type": "color", "$value": "#D8D2C1", "$description": "Hairlines, default border" },
      "400": { "$type": "color", "$value": "#B8AE96", "$description": "Disabled / lowest emphasis" }
    },
    "ink": {
      "900": { "$type": "color", "$value": "#1A1A1A", "$description": "Dark surface; never used as text on cream" },
      "800": { "$type": "color", "$value": "#2D2D2D", "$description": "Body text — warm charcoal" },
      "600": { "$type": "color", "$value": "#4A4A48", "$description": "Secondary text" },
      "400": { "$type": "color", "$value": "#6E6B62", "$description": "Tertiary text" }
    },
    "discovery": {
      "900": { "$type": "color", "$value": "#1F362C", "$description": "Signature green at max depth" },
      "700": { "$type": "color", "$value": "#2C4A3E", "$description": "Discovery Green — the Rosewood signature" },
      "300": { "$type": "color", "$value": "#7A968A", "$description": "Soft signature — sparing use" }
    },
    "gilt": {
      "600": { "$type": "color", "$value": "#B5985A", "$description": "Warm gold — line emphasis, never fill" },
      "300": { "$type": "color", "$value": "#D9C896", "$description": "Light gilt — only on dark surfaces" }
    },
    "terracotta": {
      "600": { "$type": "color", "$value": "#A56A4C", "$description": "Reserve. Spanish Colonial accent. One per property." }
    }
  },

  "color": {
    "surface": {
      "canvas": { "$type": "color", "$value": "{primitive.parchment.100}" },
      "raised": { "$type": "color", "$value": "{primitive.parchment.50}" },
      "sunken": { "$type": "color", "$value": "{primitive.parchment.200}" },
      "ink":    { "$type": "color", "$value": "{primitive.ink.900}" },
      "veil":   { "$type": "color", "$value": "rgba(26, 26, 26, 0.04)" }
    },
    "content": {
      "primary":   { "$type": "color", "$value": "{primitive.ink.800}" },
      "secondary": { "$type": "color", "$value": "{primitive.ink.600}" },
      "tertiary":  { "$type": "color", "$value": "{primitive.ink.400}" },
      "disabled":  { "$type": "color", "$value": "{primitive.sand.400}" },
      "inverse":   { "$type": "color", "$value": "{primitive.parchment.50}" }
    },
    "accent": {
      "signature":      { "$type": "color", "$value": "{primitive.discovery.700}" },
      "signature-soft": { "$type": "color", "$value": "{primitive.discovery.300}" },
      "gilt":           { "$type": "color", "$value": "{primitive.gilt.600}" },
      "terracotta":     { "$type": "color", "$value": "{primitive.terracotta.600}" }
    },
    "line": {
      "hairline": { "$type": "color", "$value": "{primitive.sand.300}" },
      "divider":  { "$type": "color", "$value": "rgba(110, 107, 98, 0.2)" },
      "emphasis": { "$type": "color", "$value": "{primitive.discovery.700}" }
    },
    "state": {
      "focus":    { "$type": "color", "$value": "rgba(44, 74, 62, 0.3)" },
      "selected": { "$type": "color", "$value": "{primitive.parchment.200}" }
    }
  },

  "font": {
    "family": {
      "serif": {
        "$type": "fontFamily",
        "$value": ["Cormorant Garamond", "Cormorant", "EB Garamond", "Georgia", "Times New Roman", "serif"]
      }
    },
    "weight": {
      "light":    { "$type": "fontWeight", "$value": 300 },
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 }
    }
  },

  "type": {
    "display-xl":  { "$type": "typography", "$value": { "fontSize": "56px", "lineHeight": "1.05", "letterSpacing": "-0.02em", "fontWeight": 300 } },
    "display-lg":  { "$type": "typography", "$value": { "fontSize": "40px", "lineHeight": "1.1",  "letterSpacing": "-0.02em", "fontWeight": 300 } },
    "heading-xl":  { "$type": "typography", "$value": { "fontSize": "28px", "lineHeight": "1.2",  "letterSpacing": "0",       "fontWeight": 600 } },
    "heading-lg":  { "$type": "typography", "$value": { "fontSize": "22px", "lineHeight": "1.25", "letterSpacing": "0",       "fontWeight": 600 } },
    "heading-md":  { "$type": "typography", "$value": { "fontSize": "19px", "lineHeight": "1.3",  "letterSpacing": "0",       "fontWeight": 600 } },
    "body-lg":     { "$type": "typography", "$value": { "fontSize": "18px", "lineHeight": "1.6",  "letterSpacing": "0",       "fontWeight": 400 } },
    "body":        { "$type": "typography", "$value": { "fontSize": "16px", "lineHeight": "1.55", "letterSpacing": "0",       "fontWeight": 400 } },
    "body-sm":     { "$type": "typography", "$value": { "fontSize": "14px", "lineHeight": "1.5",  "letterSpacing": "0",       "fontWeight": 400 } },
    "caption":     { "$type": "typography", "$value": { "fontSize": "13px", "lineHeight": "1.45", "letterSpacing": "0",       "fontWeight": 400 } },
    "micro":       { "$type": "typography", "$value": { "fontSize": "11px", "lineHeight": "1.4",  "letterSpacing": "0.08em",  "fontWeight": 500 } }
  },

  "tracking": {
    "tight":  { "$type": "dimension", "$value": "-0.02em" },
    "normal": { "$type": "dimension", "$value": "0" },
    "wide":   { "$type": "dimension", "$value": "0.08em" },
    "loose":  { "$type": "dimension", "$value": "0.16em" }
  },

  "space": {
    "0":  { "$type": "dimension", "$value": "0" },
    "px": { "$type": "dimension", "$value": "1px" },
    "1":  { "$type": "dimension", "$value": "4px" },
    "2":  { "$type": "dimension", "$value": "8px" },
    "3":  { "$type": "dimension", "$value": "12px" },
    "4":  { "$type": "dimension", "$value": "16px" },
    "5":  { "$type": "dimension", "$value": "20px" },
    "6":  { "$type": "dimension", "$value": "24px" },
    "8":  { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" },
    "16": { "$type": "dimension", "$value": "64px" },
    "20": { "$type": "dimension", "$value": "80px" },
    "24": { "$type": "dimension", "$value": "96px" },
    "32": { "$type": "dimension", "$value": "128px" },

    "semantic": {
      "$description": "Density-dependent. Defaults shown are guest mode; staff mode halves them.",
      "canvas-x":     { "$type": "dimension", "$value": "{space.16}" },
      "canvas-y":     { "$type": "dimension", "$value": "{space.20}" },
      "section":      { "$type": "dimension", "$value": "{space.12}" },
      "stack":        { "$type": "dimension", "$value": "{space.6}" },
      "inline":       { "$type": "dimension", "$value": "{space.4}" },
      "hairline-gap": { "$type": "dimension", "$value": "{space.3}" }
    },

    "density-staff": {
      "$description": "Override map applied when data-density='staff'",
      "canvas-x":     { "$type": "dimension", "$value": "{space.8}" },
      "canvas-y":     { "$type": "dimension", "$value": "{space.8}" },
      "section":      { "$type": "dimension", "$value": "{space.5}" },
      "stack":        { "$type": "dimension", "$value": "{space.3}" },
      "inline":       { "$type": "dimension", "$value": "{space.2}" },
      "hairline-gap": { "$type": "dimension", "$value": "{space.2}" }
    }
  },

  "radius": {
    "none":     { "$type": "dimension", "$value": "0" },
    "hairline": { "$type": "dimension", "$value": "2px" }
  },

  "motion": {
    "duration": {
      "quick":   { "$type": "duration", "$value": "120ms" },
      "base":    { "$type": "duration", "$value": "200ms" },
      "settle":  { "$type": "duration", "$value": "400ms" },
      "arrive":  { "$type": "duration", "$value": "600ms" }
    },
    "ease": {
      "quiet":  { "$type": "cubicBezier", "$value": [0.22, 1, 0.36, 1] },
      "linear": { "$type": "cubicBezier", "$value": [0, 0, 1, 1] }
    }
  },

  "layer": {
    "base":    { "$type": "number", "$value": 0 },
    "overlay": { "$type": "number", "$value": 100 },
    "modal":   { "$type": "number", "$value": 200 },
    "toast":   { "$type": "number", "$value": 300 }
  }
}
